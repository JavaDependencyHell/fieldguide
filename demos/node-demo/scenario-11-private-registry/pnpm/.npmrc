# tag::n11-scoped[]
# SAFER STILL: default registry stays public, but the @acme scope is
# pinned to the private registry — and nobody else can publish @acme/*
# there. Scoping is the mitigation Python's flat namespace doesn't have.
registry=http://127.0.0.1:4873/
@acme:registry=http://127.0.0.1:4874/
# end::n11-scoped[]
